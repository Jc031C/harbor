{
  "app": {
    "name": "Harbor",
    "version": "0.1.1",
    "debug": true
  },
  "bridge": {
    "default": "mock"
  },
  "workers": {
    "enabled": [
      "mock_worker",
      "system_worker",
      "gpt_desktop_worker"
    ]
  },
  "permission": {
    "whitelist": [
      "developer"
    ]
  },
  "gpt_desktop": {
    "enabled": false
  },
  "logs": {
    "path": "data/logs/harbor.log"
  }
}
